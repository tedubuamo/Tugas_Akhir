jobmatcher.legain.id {
    # API routes — proxied to Flask backend
    handle /extract-cv/* {
        reverse_proxy backend:5002
    }
    handle /set-groq-key/* {
        reverse_proxy backend:5002
    }
    handle /api/* {
        reverse_proxy backend:5002
    }

    # Frontend static files
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }

    encode gzip
}
